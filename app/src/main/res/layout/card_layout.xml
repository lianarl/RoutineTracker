<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/card_view"
    android:layout_margin="20dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:contentPadding="4dp"
    android:foreground="?selectableItemBackground"
    android:clickable="true">

    <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

        <TextView
                android:id="@+id/routine_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:text="Routine name"
                />

        <TextView
                android:id="@+id/routine_completed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignBaseline="@id/routine_name"
                android:textColor="#3B9BFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="Completed"
                />

        <TextView
                android:id="@+id/routine_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:layout_below="@id/routine_name"
                android:layout_alignParentStart="true"
                android:text="Type"
                />

        <TextView
                android:id="@+id/routine_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/routine_type"
                android:layout_alignParentStart="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:text="12:00 - 13:00"
                />

        <TextView
                android:id="@+id/routine_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/routine_type"
                android:layout_marginTop="6dp"
                android:layout_alignParentEnd="true"
                android:textSize="14sp"
                android:textColor="#000000"
                android:text="Mon, Fri"
                />

    </RelativeLayout>

</androidx.cardview.widget.CardView>
