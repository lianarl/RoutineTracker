<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.AddEditRoutineFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/addedit_name"
            android:layout_width="wrap_content"
            android:hint="Enter routine name"
            android:paddingTop="100dp"
            android:layout_height="wrap_content"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select the routine type"
            android:layout_marginTop="25dp" />

        <Spinner
            android:id="@+id/addedit_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="30dp">

            <Button
                android:id="@+id/addedit_start"
                android:layout_width="140dp"
                android:layout_height="60dp"
                android:text="Select start time"
                android:layout_marginRight="10dp"
                />

            <Button
                android:id="@+id/addedit_end"
                android:layout_width="140dp"
                android:layout_height="60dp"
                android:text="Select end time"
                android:layout_marginLeft="10dp"
                />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="30dp">

            <CheckBox
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/cbMon"
                android:text="Mon"/>

            <CheckBox
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/cbTue"
                android:text="Tue"/>

            <CheckBox
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/cbWed"
                android:text="Wed"/>

            <CheckBox
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/cbThu"
                android:text="Thu"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <CheckBox
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/cbFri"
                android:text="Fri"/>

            <CheckBox
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/cbSat"
                android:text="Sat"/>

            <CheckBox
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/cbSun"
                android:text="Sun"/>

        </LinearLayout>

        <Switch
            android:id="@+id/addedit_notif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable notifications"
            android:layout_marginTop="30dp"/>

        <Button
            android:id="@+id/addedit_save"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginTop="30dp"/>

    </LinearLayout>

</ScrollView>